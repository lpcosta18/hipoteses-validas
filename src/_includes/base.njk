{# src/_includes/base.njk #}
<!DOCTYPE html>
<html lang="pt-PT" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    
    {# SEO Básico #}
    <title>{{ title }} | Hipóteses Válidas</title>
    <meta name="description" content="{{ description | default('Contabilidade, Fiscalidade e Apoio à Gestão com rigor e proximidade em Torres Vedras') }}">
    <meta name="author" content="Hipóteses Válidas, Lda.">
    
    {# Open Graph / Social Sharing #}
    <meta property="og:type" content="website">
    <meta property="og:locale" content="pt_PT">
    <meta property="og:title" content="{{ title }} | Hipóteses Válidas">
    <meta property="og:description" content="{{ description | default('Contabilidade e Fiscalidade em Torres Vedras') }}">
    <meta property="og:url" content="{{ siteUrl | default('https://hipoteses-validas.pt') }}">
    <meta property="og:image" content="{{ siteUrl | default('https://hipoteses-validas.pt') }}/assets/logo/logo-hv-home-neg-optimized.png">
    
    {# Favicon #}
    <link rel="icon" type="image/png" href="/assets/logo/favicon.png">
    
    {# CSS Principal #}
    <link rel="stylesheet" href="/style.css">
    
    {# Font Awesome 6.5.1 - CDN (Carregamento Assíncrono) #}
    <link 
      rel="preload" 
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" 
      as="style" 
      onload="this.onload=null;this.rel='stylesheet'"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous" 
      referrerpolicy="no-referrer"
    >
    <noscript>
      <link 
        rel="stylesheet" 
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" 
        integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
        crossorigin="anonymous" 
        referrerpolicy="no-referrer"
      >
    </noscript>
    
    {# Fonts Locais (se aplicável) #}
    {% if fonts %}
    <link rel="preload" href="/fonts/NeueRegrade/NeueRegrade-Regular.woff2" as="font" type="font/woff2" crossorigin>
    {% endif %}
    
    {# Scripts no Head (se necessário) #}
    {% block head %}{% endblock %}
</head>

<body class="bg-white text-dark antialiased">
    {# Skip Link para Acessibilidade #}
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-ouro-claro text-white px-4 py-2 rounded z-50">
        Saltar para o conteúdo principal
    </a>
    
    {# Header #}
    {% include "header.njk" %}
    
    {# Conteúdo Principal #}
    <main id="main-content" class="min-h-screen">
        {{ content | safe }}
    </main>
    
    {# Footer #}
    {% include "footer.njk" %}
    
    {# Scripts no Final do Body #}
    <script src="/script.js" defer></script>
    <script src="/header.js" defer></script>
    
    {# Scripts Inline (se necessário) #}
    {% block scripts %}{% endblock %}
</body>
</html>