{# src/_includes/header.njk #}
{# Header Component - Hipóteses Válidas #}

<header class="header">
    <div class="header-container container">
        
        {# === Logo === #}
        <a href="/" class="logo" aria-label="Hipóteses Válidas - Página Inicial">
            <img src="/assets/logo/logo-hv-home-neg.webp"
                 srcset="/assets/logo/logo-hv-home-neg-300.webp 300w,
                         /assets/logo/logo-hv-home-neg-600.webp 600w,
                         /assets/logo/logo-hv-home-neg.webp 1000w"
                 sizes="(max-width: 768px) 150px, 200px"
                 alt="Hipóteses Válidas - Contabilidade e Fiscalidade em Torres Vedras"
                 class="logo-img"
                 width="200"
                 height="40"
                 loading="eager">
        </a>
        
        {# === Menu Desktop === #}
        <nav class="nav-desktop" aria-label="Navegação principal">
            <ul class="nav-list">
                <li><a href="/" class="nav-link">Início</a></li>
                <li><a href="/sobre/" class="nav-link">Sobre</a></li>
                <li><a href="/servicos/" class="nav-link">Serviços</a></li>
                <li><a href="/contacto/" class="nav-link">Contactos</a></li>
            </ul>
        </nav>

        {# === Telefone Desktop === #}
        <a href="tel:+351968481817" class="btn btn-primary btn-phone">
            <svg class="btn-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            968 481 817
        </a>
        
        {# === Menu Mobile Toggle === #}
        <button class="menu-toggle" 
                aria-label="Abrir menu" 
                aria-expanded="false" 
                aria-controls="mobile-menu"
                type="button">
            <span class="menu-toggle-line"></span>
            <span class="menu-toggle-line"></span>
            <span class="menu-toggle-line"></span>
        </button>
    </div>
    
    {# === Menu Mobile Dropdown === #}
    <div class="menu-mobile" id="mobile-menu" hidden>
        <nav class="menu-mobile-nav" aria-label="Navegação mobile">
            <ul class="menu-mobile-list">
                <li><a href="/" class="mobile-link">Início</a></li>
                <li><a href="/sobre/" class="mobile-link">Sobre</a></li>
                <li><a href="/servicos/" class="mobile-link">Serviços</a></li>
                <li><a href="/contacto/" class="mobile-link">Contactos</a></li>
                <li>
                    <a href="tel:+351968481817" class="mobile-link mobile-link-phone">
                        <svg class="mobile-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                        </svg>
                        968 481 817
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</header>

{# === Script para Menu Mobile (inline para performance) === #}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const toggle = document.querySelector('.menu-toggle');
    const menu = document.querySelector('#mobile-menu');
    
    if (toggle && menu) {
        toggle.addEventListener('click', function() {
            const expanded = this.getAttribute('aria-expanded') === 'true';
            this.setAttribute('aria-expanded', !expanded);
            menu.hidden = expanded;
            document.body.style.overflow = expanded ? '' : 'hidden';
        });
        
        // Fechar menu ao clicar num link
        menu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', function() {
                toggle.setAttribute('aria-expanded', 'true');
                menu.hidden = true;
                document.body.style.overflow = '';
            });
        });
        
        // Fechar com Escape
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && !menu.hidden) {
                toggle.setAttribute('aria-expanded', 'true');
                menu.hidden = true;
                document.body.style.overflow = '';
                toggle.focus();
            }
        });
    }
});
</script>