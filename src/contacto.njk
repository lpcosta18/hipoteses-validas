{# Form Script #}
<script>
// Reset form UI
function resetContactForm() {
    const form = document.getElementById('contactForm');
    const success = document.getElementById('formSuccess');
    const error = document.getElementById('formError');
    
    form.reset();
    form.hidden = false;
    form.style.display = '';
    success.hidden = true;
    error.hidden = true;
    
    // Clear error states
    document.querySelectorAll('.form-control, .form-select, .form-textarea').forEach(el => {
        el.classList.remove('error');
    });
    document.querySelectorAll('.form-error-text').forEach(el => {
        el.style.display = 'none';
    });
}

// Form submission
document.getElementById('contactForm')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const form = this;
    const submitBtn = document.getElementById('submitBtn');
    const success = document.getElementById('formSuccess');
    const error = document.getElementById('formError');
    
    // Clear previous errors
    document.querySelectorAll('.form-error-text').forEach(el => el.style.display = 'none');
    document.querySelectorAll('.form-control, .form-select, .form-textarea').forEach(el => el.classList.remove('error'));
    
    // Validate required fields
    let isValid = true;
    
    const requiredFields = [
        { id: 'nome', message: 'Este campo é obrigatório' },
        { id: 'email', message: 'Email inválido', validator: v => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) },
        { id: 'assunto', message: 'Selecione um assunto' },
        { id: 'mensagem', message: 'Este campo é obrigatório' },
        { id: 'privacidade', message: 'Deve aceitar a política de privacidade', type: 'checkbox' }
    ];
    
    requiredFields.forEach(({ id, message, validator, type }) => {
        const field = document.getElementById(id);
        const errorEl = document.getElementById(id + 'Error');
        let value = type === 'checkbox' ? field.checked : field.value.trim();
        
        if (!value || (validator && !validator(value))) {
            if (errorEl) errorEl.style.display = 'block';
            if (field.tagName !== 'INPUT' || type !== 'checkbox') field.classList.add('error');
            isValid = false;
        }
    });
    
    if (!isValid) return;
    
    // Loading state
    const originalBtnText = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="btn-loading">A enviar...</span>';
    
    try {
        // Prepare payload
        const payload = {
            nome: document.getElementById('nome').value.trim(),
            email: document.getElementById('email').value.trim(),
            empresa: document.getElementById('empresa').value.trim(),
            telemovel: document.getElementById('telemovel').value.trim(),
            assunto: document.getElementById('assunto').value,
            mensagem: document.getElementById('mensagem').value.trim(),
            privacidade: document.getElementById('privacidade').checked,
            origin: window.location.href
        };
        
        // Get API key from form data attribute or fallback
        const apiKey = form.dataset.apiKey || '';
        
        // Submit to API
        const response = await fetch('/api/sendContact', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                ...(apiKey && { 'x-api-key': apiKey })
            },
            body: JSON.stringify(payload)
        });
        
        const result = await response.json();
        
        if (!response.ok) {
            throw new Error(result.error || 'Erro ao enviar mensagem');
        }
        
        // Success: hide form, show success message
        form.hidden = true;
        form.style.display = 'none';
        success.hidden = false;
        
    } catch (err) {
        console.error('Form submission error:', err);
        error.hidden = false;
        document.getElementById('formErrorMessage').textContent = 
            err.message || 'Erro ao enviar mensagem. Tente novamente.';
    } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalBtnText;
    }
});

// Prevent error message showing on page load
document.addEventListener('DOMContentLoaded', function() {
    const error = document.getElementById('formError');
    const success = document.getElementById('formSuccess');
    if (error) error.hidden = true;
    if (success) success.hidden = true;
});
</script>